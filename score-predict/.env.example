# Unified Supabase (hankuk-main) - fire bridge schema for server reads
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-1-ap-northeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&sslmode=require&schema=score_predict_fire"

# Unified Supabase (hankuk-main) - direct session pooler for Prisma tooling
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-1-ap-northeast-2.pooler.supabase.com:5432/postgres?sslmode=require&schema=score_predict_fire"

NEXTAUTH_SECRET="change-this-to-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
SUPABASE_URL="https://<project-ref>.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="<service-role-key>"
SUPABASE_STORAGE_BUCKET="uploads"
CRON_SECRET="change-this-cron-secret"

# Optional: seed admin account
ADMIN_PHONE="010-0000-0000"
ADMIN_PASSWORD="admin1234!"

# Optional: password reset email provider
# Option A: Resend API
RESEND_API_KEY=""
MAIL_FROM="noreply@example.com"
PASSWORD_RESET_MAIL_SUBJECT="[Police Pass Prediction] Password Reset Guide"

# Option B: custom webhook endpoint
PASSWORD_RESET_MAIL_WEBHOOK_URL=""
PASSWORD_RESET_MAIL_WEBHOOK_TOKEN=""

# Show reset link directly in API response for local/dev
PASSWORD_RESET_DEBUG_LINK="false"
