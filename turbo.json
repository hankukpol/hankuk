{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "NEXT_PUBLIC_SUPABASE_URL",
    "NEXT_PUBLIC_SUPABASE_ANON_KEY",
    "SUPABASE_SERVICE_ROLE_KEY",
    "COOKIE_DOMAIN"
  ],
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        ".next/**",
        "!.next/cache/**",
        "dist/**",
        "build/**"
      ]
    },
    "fire-exam-prediction#build": {
      "dependsOn": [
        "^build"
      ],
      "env": [
        "DATABASE_URL",
        "DIRECT_URL",
        "NEXTAUTH_SECRET",
        "NEXTAUTH_URL",
        "SUPABASE_URL",
        "SUPABASE_STORAGE_BUCKET",
        "CRON_SECRET"
      ],
      "outputs": [
        ".next/**",
        "!.next/cache/**"
      ]
    },
    "web#build": {
      "dependsOn": [
        "^build"
      ],
      "env": [
        "DATABASE_URL",
        "DIRECT_URL",
        "NEXT_PUBLIC_APP_URL",
        "SEED_SUPER_ADMIN_EMAIL",
        "SEED_SUPER_ADMIN_PASSWORD",
        "SEED_SUPER_ADMIN_NAME"
      ],
      "outputs": [
        ".next/**",
        "!.next/cache/**"
      ]
    },
    "police-interview-mobile-pass#build": {
      "dependsOn": [
        "^build"
      ],
      "env": [
        "NEXT_PUBLIC_APP_URL",
        "ADMIN_KEY"
      ],
      "outputs": [
        ".next/**",
        "!.next/cache/**"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "outputs": []
    },
    "typecheck": {
      "outputs": []
    }
  }
}
