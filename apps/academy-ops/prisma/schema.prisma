  description   String?
  defaultAmount Int
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([isActive])
  @@map("point_policies")
}

// ---------------------------------------------------------------------------

// ---------------------------------------------------------------------------

enum LinkStatus {
  ACTIVE
  EXPIRED
  DISABLED
  USED_UP
}

model PaymentLink {
  id       Int    @id @default(autoincrement())
  token    String @unique @default(cuid())
  title    String
  courseId Int?

  examNumber       String?
  cohortId         String?
  productId        String?
  courseType       CourseType?
  specialLectureId String?
  amount           Int
  discountAmount   Int         @default(0)
  finalAmount      Int
  allowPoint       Boolean     @default(true)
  expiresAt        DateTime
  maxUsage         Int?
  usageCount       Int         @default(0)
  status           LinkStatus  @default(ACTIVE)
  note             String?
  createdBy        String      @db.Uuid
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  course         Course?                     @relation(fields: [courseId], references: [id], onDelete: SetNull)
  student        Student?                    @relation(fields: [examNumber], references: [examNumber], onDelete: SetNull)
  cohort         Cohort?                     @relation(fields: [cohortId], references: [id], onDelete: SetNull)
  product        ComprehensiveCourseProduct? @relation(fields: [productId], references: [id], onDelete: SetNull)
  specialLecture SpecialLecture?             @relation(fields: [specialLectureId], references: [id], onDelete: SetNull)
  staff          AdminUser                   @relation(fields: [createdBy], references: [id])
  payments       Payment[]

  @@index([token])
  @@index([status])
  @@index([createdBy])
  @@index([examNumber])
  @@map("payment_links")
}

model CourseContract {
  id                 String    @id @default(cuid())
  enrollmentId       String    @unique
  items              Json      @default("[]")
  note               String?
  issuedAt           DateTime  @default(now())
  printedAt          DateTime?
  privacyConsentedAt DateTime?
  staffId            String    @db.Uuid

  enrollment CourseEnrollment @relation(fields: [enrollmentId], references: [id])
  staff      AdminUser        @relation(fields: [staffId], references: [id])

  @@index([staffId])
  @@index([privacyConsentedAt])
  @@map("course_contracts")
}

enum ProspectSource {
  WALK_IN
  PHONE
  SNS
  REFERRAL
  OTHER
}

enum ProspectStage {
  INQUIRY
  VISITING
  DECIDING
  REGISTERED
  DROPPED
}

model ConsultationProspect {
  id           String         @id @default(cuid())
  name         String
  phone        String?
  examType     ExamType?
  source       ProspectSource @default(WALK_IN)
  stage        ProspectStage  @default(INQUIRY)
  note         String?
  staffId      String         @db.Uuid
  enrollmentId String?
  visitedAt    DateTime       @default(now())
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  staff AdminUser @relation(fields: [staffId], references: [id])

  @@index([stage])
  @@index([staffId])
  @@index([visitedAt])
  @@map("consultation_prospects")
}

enum ExamEventType {
  MORNING
  MONTHLY
  SPECIAL
  EXTERNAL

  @@map("ExamEventType")
}

enum ExamDivision {
  GONGCHAE_M
  GONGCHAE_F
  GYEONGCHAE
  ONLINE

  @@map("ExamDivision")
}

model ExamEvent {
  id                   String        @id @default(cuid())
  title                String
  eventType            ExamEventType
  examDate             DateTime
  registrationFee      Int           @default(0)
  registrationDeadline DateTime?
  venue                String?
  isActive             Boolean       @default(true)
  createdAt            DateTime      @default(now())

  registrations ExamRegistration[]

  @@index([eventType, examDate])
  @@map("exam_events")
}

model ExamRegistration {
  id            String       @id @default(cuid())
  examEventId   String
  examNumber    String?
  externalName  String?
  externalPhone String?
  division      ExamDivision
  isPaid        Boolean      @default(false)
  paidAmount    Int          @default(0)
  paidAt        DateTime?
  seatNumber    String?
  registeredAt  DateTime     @default(now())
  cancelledAt   DateTime?

  examEvent ExamEvent  @relation(fields: [examEventId], references: [id], onDelete: Cascade)
  student   Student?   @relation(fields: [examNumber], references: [examNumber], onDelete: SetNull)
  score     ExamScore?

  @@index([examEventId, division])
  @@index([examNumber])
  @@map("exam_registrations")
}

model ExamScore {
  id             String   @id @default(cuid())
  registrationId String   @unique
  score          Float
  rank           Int?
  note           String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  registration ExamRegistration @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  @@index([registrationId])
  @@map("exam_scores")
}

enum AttendStatus {
  PRESENT
  LATE
  ABSENT
  EXCUSED

  @@map("AttendStatus")
}

model LectureSchedule {
  id             String   @id @default(cuid())
  cohortId       String
  subjectName    String
  instructorName String?
  dayOfWeek      Int
  startTime      String // "09:00"
  endTime        String // "11:00"
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  cohort   Cohort           @relation(fields: [cohortId], references: [id], onDelete: Cascade)
  sessions LectureSession[]

  @@index([cohortId])
  @@map("lecture_schedules")
}

model LectureSession {
  id          String   @id @default(cuid())
  scheduleId  String
  sessionDate DateTime @db.Date
  startTime   String
  endTime     String
  isCancelled Boolean  @default(false)
  note        String?
  createdAt   DateTime @default(now())

  schedule    LectureSchedule     @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  attendances LectureAttendance[]

  @@unique([scheduleId, sessionDate])
  @@index([sessionDate])
  @@map("lecture_sessions")
}

model LectureAttendance {
  id        String       @id @default(cuid())
  sessionId String
  studentId String // Student.examNumber
  status    AttendStatus @default(PRESENT)
  note      String?
  checkedAt DateTime     @default(now())
  checkedBy String?      @db.Uuid

  session LectureSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student Student        @relation(fields: [studentId], references: [examNumber], onDelete: Cascade)

  @@unique([sessionId, studentId])
  @@index([studentId])
  @@map("lecture_attendances")
}
