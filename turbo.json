{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "NEXT_PUBLIC_SUPABASE_URL",
    "NEXT_PUBLIC_SUPABASE_ANON_KEY",
    "SUPABASE_SERVICE_ROLE_KEY",
    "COOKIE_DOMAIN"
  ],
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        ".next/**",
        "!.next/cache/**",
        "dist/**",
        "build/**"
      ]
    },
    "fire-exam-prediction#build": {
      "dependsOn": [
        "^build"
      ],
      "env": [
        "DATABASE_URL",
        "DIRECT_URL",
        "NEXTAUTH_SECRET",
        "NEXTAUTH_URL",
        "SUPABASE_URL",
        "SUPABASE_STORAGE_BUCKET",
        "CRON_SECRET"
      ],
      "outputs": [
        ".next/**",
        "!.next/cache/**"
      ]
    },
    "academy-ops#build": {
      "dependsOn": [
        "^build"
      ],
      "env": [
        "DATABASE_URL",
        "DIRECT_URL",
        "NEXT_PUBLIC_SUPABASE_URL",
        "NEXT_PUBLIC_SUPABASE_ANON_KEY",
        "SUPABASE_SERVICE_ROLE_KEY",
        "NEXT_PUBLIC_APP_URL",
        "NEXT_PUBLIC_PORTONE_STORE_ID",
        "NEXT_PUBLIC_PORTONE_CHANNEL_KEY",
        "STUDENT_JWT_SECRET",
        "CRON_SECRET",
        "NEXT_PUBLIC_VAPID_PUBLIC_KEY",
        "VAPID_PRIVATE_KEY",
        "VAPID_SUBJECT",
        "SEED_SUPER_ADMIN_EMAIL",
        "SEED_SUPER_ADMIN_PASSWORD",
        "SEED_SUPER_ADMIN_NAME"
      ],
      "outputs": [
        ".next/**",
        "!.next/cache/**"
      ]
    },
    "police-interview-mobile-pass#build": {
      "dependsOn": [
        "^build"
      ],
      "env": [
        "NEXT_PUBLIC_APP_URL",
        "ADMIN_KEY"
      ],
      "outputs": [
        ".next/**",
        "!.next/cache/**"
      ]
    },
    "class-pass#build": {
      "dependsOn": [
        "^build"
      ],
      "env": [
        "NEXT_PUBLIC_APP_URL",
        "NEXT_PUBLIC_TENANT_TYPE",
        "JWT_SECRET",
        "QR_HMAC_SECRET"
      ],
      "outputs": [
        ".next/**",
        "!.next/cache/**"
      ]
    },
    "portal#build": {
      "dependsOn": [
        "^build"
      ],
      "env": [
        "NEXT_PUBLIC_SUPABASE_URL",
        "NEXT_PUBLIC_SUPABASE_ANON_KEY",
        "SUPABASE_SERVICE_ROLE_KEY",
        "PORTAL_JWT_SECRET",
        "APP_SESSION_SECRET",
        "JWT_SECRET",
        "PORTAL_TARGET_CLASS_PASS_URL",
        "PORTAL_TARGET_STUDY_HALL_URL",
        "PORTAL_TARGET_INTERVIEW_PASS_URL"
      ],
      "outputs": [
        ".next/**",
        "!.next/cache/**"
      ]
    },
    "interview-mate#build": {
      "dependsOn": [
        "^build"
      ],
      "env": [
        "NEXT_PUBLIC_SUPABASE_URL",
        "NEXT_PUBLIC_SUPABASE_ANON_KEY",
        "SUPABASE_SERVICE_ROLE_KEY",
        "ADMIN_KEY",
        "NEXT_PUBLIC_VAPID_PUBLIC_KEY",
        "VAPID_PRIVATE_KEY"
      ],
      "outputs": [
        ".next/**",
        "!.next/cache/**"
      ]
    },
    "police-exam-bank#build": {
      "dependsOn": [
        "^build"
      ],
      "env": [
        "NEXT_PUBLIC_SUPABASE_URL",
        "NEXT_PUBLIC_SUPABASE_ANON_KEY",
        "SUPABASE_SERVICE_ROLE_KEY",
        "LAW_API_KEY",
        "MCP_SERVER_URL"
      ],
      "outputs": [
        ".next/**",
        "!.next/cache/**"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "outputs": []
    },
    "typecheck": {
      "outputs": []
    }
  }
}
