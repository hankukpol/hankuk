{
  "name": "hankuk",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "prepare:pnpm": "corepack prepare pnpm@10.0.0 --activate",
    "dev:score-predict": "pnpm --dir ./apps/score-predict dev",
    "dev:study-hall": "pnpm --dir ./apps/study-hall dev",
    "dev:interview-pass": "pnpm --dir ./apps/interview-pass dev",
    "dev:academy-ops": "pnpm --dir ./apps/academy-ops dev",
    "dev:interview-mate": "pnpm --dir ./apps/interview-mate dev",
    "build:score-predict": "pnpm --dir ./apps/score-predict build",
    "build:study-hall": "pnpm --dir ./apps/study-hall build",
    "build:interview-pass": "pnpm --dir ./apps/interview-pass build",
    "build:academy-ops": "pnpm --dir ./apps/academy-ops build",
    "build:interview-mate": "pnpm --dir ./apps/interview-mate build",
    "turbo:build": "pnpm exec turbo run build",
    "turbo:lint": "pnpm exec turbo run lint",
    "turbo:typecheck": "pnpm exec turbo run typecheck",
    "turbo:dev": "pnpm exec turbo run dev --parallel"
  },
  "devDependencies": {
    "pnpm": "10.0.0",
    "turbo": "^2.5.8"
  }
}
