NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<publishable-or-anon-key>"
SUPABASE_SERVICE_ROLE_KEY="<service-role-key>"

# Portal session signing secret
PORTAL_JWT_SECRET="change-me-long-random-secret"
PORTAL_ORIGIN="https://portal.hankukpol.co.kr"
PORTAL_ALLOWED_ORIGINS="https://portal.hankukpol.co.kr,https://portal-hankuk.vercel.app"

# Prefer canonical custom domains like https://score.hankukpol.co.kr when set to true.
PORTAL_PREFER_CUSTOM_DOMAINS="true"

# Optional per-app overrides for local development or preview routing.
PORTAL_TARGET_ACADEMY_OPS_URL="http://localhost:3106"
PORTAL_TARGET_CLASS_PASS_URL="http://localhost:3002"
PORTAL_TARGET_SCORE_PREDICT_URL="http://localhost:3003"
PORTAL_TARGET_STUDY_HALL_URL="http://localhost:3004"
PORTAL_TARGET_INTERVIEW_PASS_URL="http://localhost:3005"
