    "@types/web-push": "^3.6.4",
    "autoprefixer": "^10.4.27",
    "babel-loader": "^10.1.1",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.35",
    "postcss": "^8.5.8",
    "prisma": "^6.19.2",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
