# Transitional default tenant for local/dev only.
# Production should resolve police/fire from the request path.
NEXT_PUBLIC_TENANT_TYPE=police

# Unified Supabase (hankuk-main) - interview schema shared by police/fire
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# JWT signing secret (minimum 32 random characters)
JWT_SECRET=replace-with-a-32-char-random-secret

# QR token HMAC secret (minimum 32 random characters)
QR_HMAC_SECRET=replace-with-a-32-char-random-secret

# Local public URL
# In Vercel production, set this to the actual deployment domain.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: enable when the custom domain cutover to *.hankukpol.co.kr is complete.
COOKIE_DOMAIN=
