{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "node scripts/ensure-prisma-generated.cjs && next dev",
    "build": "node scripts/ensure-prisma-generated.cjs && node scripts/clean-build-artifacts.cjs && next build",
    "start": "node scripts/ensure-prisma-generated.cjs && next start",
    "lint": "node scripts/ensure-prisma-generated.cjs && next lint",
    "typecheck": "node scripts/ensure-prisma-generated.cjs && tsc --noEmit",
    "prisma:generate": "node scripts/ensure-prisma-generated.cjs --force",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "node scripts/ensure-prisma-generated.cjs && prisma db seed",
    "reset:all": "node scripts/reset-all-data.mjs",
    "smoke:test": "node scripts/smoke-test.mjs"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@prisma/client": "^6.19.0",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.100.1",
    "exceljs": "^4.4.0",
    "framer-motion": "^12.38.0",
    "iconv-lite": "^0.7.2",
    "jose": "^6.2.2",
    "lucide-react": "^0.577.0",
    "next": "14.2.35",
    "prisma": "^6.19.0",
    "react": "^18",
    "react-dom": "^18",
    "recharts": "^3.8.0",
    "sonner": "^2.0.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.20.6",
    "typescript": "^5"
  }
}
