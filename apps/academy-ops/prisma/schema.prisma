generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Student {
  examNumber          String        @id
  academyId           Int?
  name                String
  phone               String?
  email               String?
  birthDate           DateTime?
  generation          Int?
  className           String?
  examType            ExamType
  studentType         StudentType   @default(EXISTING)
  onlineId            String?       @unique
  registeredAt        DateTime?
  note                String?
  isActive            Boolean       @default(true)
  notificationConsent Boolean       @default(false)
  consentedAt         DateTime?
  targetScores        Json?
  currentStatus       StudentStatus @default(NORMAL)
  statusUpdatedAt     DateTime?

  parentName     String?
  parentRelation String?
  parentMobile   String?

  emergencyContactName     String?
  emergencyContactPhone    String?
  emergencyContactRelation String?
  address                  String?
  zipCode                  String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  absenceNotes               AbsenceNote[]
  counselingAppointments     CounselingAppointment[]
  counselingRecords          CounselingRecord[]
  enrollments                PeriodEnrollment[]
  notifications              NotificationLog[]
  pointLogs                  PointLog[]
  pushSubscriptions          PushSubscription[]
  scores                     Score[]
  studentAnswers             StudentAnswer[]
  weeklyStatusSnapshots      WeeklyStatusSnapshot[]
  wrongNoteBookmarks         WrongNoteBookmark[]
  courseEnrollments          CourseEnrollment[]
  payments                   Payment[]
  classroomStudents          ClassroomStudent[]
  classroomAttendanceResults ClassroomAttendanceResult[] @relation("ClassroomAttendanceResultStudent")
  classroomAttendanceLogs    ClassroomAttendanceLog[]    @relation("ClassroomAttendanceLogStudent")
  lockerRentals              LockerRental[]
  studyRoomBookings          StudyRoomBooking[]
  graduateRecords            GraduateRecord[]
  discountCodeUsages         DiscountCodeUsage[]
  examRegistrations          ExamRegistration[]
  lectureAttendances         LectureAttendance[]
  paymentLinks               PaymentLink[]
  documentIssuances          DocumentIssuance[]
  pointBalance               PointBalance?
  memberProfile              MemberProfile?

  academy Academy? @relation(fields: [academyId], references: [id], onDelete: SetNull)

  @@index([academyId])
  @@index([academyId, examType, isActive])
  @@index([academyId, examType, isActive, currentStatus])
  @@index([academyId, examType, generation, isActive, examNumber])
  @@index([examType, isActive])
  @@index([examType, isActive, currentStatus])
  @@index([examType, generation, isActive, examNumber])
  @@index([studentType])
  @@map("students")
}

model MemberProfile {
  examNumber     String        @id
  photoUrl       String?
  enrollSource   EnrollSource?
  status         MemberStatus  @default(ACTIVE)
  suspendedAt    DateTime?
  withdrawnAt    DateTime?
  withdrawReason String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  student Student @relation(fields: [examNumber], references: [examNumber], onDelete: Cascade)

  @@index([status])
  @@index([enrollSource])
  @@map("member_profiles")
}

model PushSubscription {
  id         String   @id @default(cuid())
  examNumber String
  endpoint   String   @unique
  p256dh     String
  auth       String
  userAgent  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  student Student @relation(fields: [examNumber], references: [examNumber], onDelete: Cascade)

  @@index([examNumber, updatedAt])
  @@map("push_subscriptions")
}

model ExamPeriod {
  id                  Int      @id @default(autoincrement())
  academyId           Int?
  name                String
  startDate           DateTime
  endDate             DateTime
  totalWeeks          Int      @default(8)
  isActive            Boolean  @default(false)
  isGongchaeEnabled   Boolean  @default(true)
  isGyeongchaeEnabled Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  academy Academy? @relation(fields: [academyId], references: [id], onDelete: SetNull)

  enrollments           PeriodEnrollment[]
  monthlyResults        MonthlyResult[]
  pointLogs             PointLog[]
  sessions              ExamSession[]
  weeklyStatusSnapshots WeeklyStatusSnapshot[]

  @@index([academyId, isActive])
  @@map("exam_periods")
}

model MonthlyResult {
  id          Int       @id @default(autoincrement())
  periodId    Int
  month       Int
  year        Int
  publishedAt DateTime?
  isPublished Boolean   @default(false)

  period ExamPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)

  @@unique([periodId, year, month])
  @@map("monthly_results")
}

model ExamSession {
  id                 Int       @id @default(autoincrement())
  periodId           Int
  examType           ExamType
  week               Int
  subject            Subject
  displaySubjectName String?
  examDate           DateTime
  isCancelled        Boolean   @default(false)
  cancelReason       String?
  isLocked           Boolean   @default(false)
  lockedAt           DateTime?
  lockedBy           String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  absenceNotes        AbsenceNote[]
  relatedAdminMemos   AdminMemo[]             @relation("AdminMemoRelatedExamSession")
  period              ExamPeriod              @relation(fields: [periodId], references: [id], onDelete: Cascade)
  questions           ExamQuestion[]
  scoreDeadlineAlerts ScoreDeadlineAlertLog[]
  scores              Score[]

  @@unique([periodId, examType, examDate, subject])
  @@index([periodId, examType, week])
  @@index([periodId, examType, examDate])
  @@map("exam_sessions")
}

model ExamSubject {
  id           Int      @id @default(autoincrement())
  academyId    Int
  examType     ExamType
  code         Subject
  displayName  String
  shortLabel   String
  displayOrder Int
  maxScore     Int      @default(100)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  academy Academy @relation(fields: [academyId], references: [id], onDelete: Cascade)

  @@unique([academyId, examType, code])
  @@index([academyId, examType, isActive, displayOrder])
  @@map("exam_subjects")
}

model Score {
  id         Int         @id @default(autoincrement())
  academyId  Int?
  examNumber String
  sessionId  Int
  rawScore   Float?
  oxScore    Float?
  finalScore Float?
  attendType AttendType
  sourceType ScoreSource
  note       String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  academy Academy? @relation(fields: [academyId], references: [id], onDelete: SetNull)

  session ExamSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student Student     @relation(fields: [examNumber], references: [examNumber], onDelete: Cascade)

  @@unique([examNumber, sessionId])
  @@index([academyId, sessionId])
  @@index([academyId, examNumber])
  @@index([sessionId])
  @@index([examNumber])
  @@map("scores")
}

model AbsenceNote {
  id                            Int              @id @default(autoincrement())
  academyId                     Int?
  examNumber                    String
  sessionId                     Int
  reason                        String
  absenceCategory               AbsenceCategory?
  submittedAt                   DateTime?
  approvedAt                    DateTime?
  status                        AbsenceStatus    @default(PENDING)
  attendCountsAsAttendance      Boolean          @default(false)
  attendGrantsPerfectAttendance Boolean          @default(false)
  adminNote                     String?
  createdAt                     DateTime         @default(now())
  updatedAt                     DateTime         @updatedAt

  academy Academy? @relation(fields: [academyId], references: [id], onDelete: SetNull)

  attachments AbsenceNoteAttachment[]
  session     ExamSession             @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student     Student                 @relation(fields: [examNumber], references: [examNumber], onDelete: Cascade)

  @@unique([examNumber, sessionId])
  @@index([academyId, status, submittedAt])
  @@index([academyId, sessionId, status])
  @@index([status, submittedAt])
  @@index([sessionId, status])
  @@map("absence_notes")
}

model AbsenceNoteAttachment {
  id                Int      @id @default(autoincrement())
  noteId            Int
  bucket            String
  storagePath       String
  originalFileName  String
  contentType       String
  byteSize          Int
  uploadedByAdminId String?  @db.Uuid
  createdAt         DateTime @default(now())

  note            AbsenceNote @relation(fields: [noteId], references: [id], onDelete: Cascade)
  uploadedByAdmin AdminUser?  @relation("AbsenceNoteAttachmentUploader", fields: [uploadedByAdminId], references: [id], onDelete: SetNull)

  @@unique([bucket, storagePath])
  @@index([noteId, createdAt])
  @@map("absence_note_attachments")
}

model AbsencePolicy {
  id                            Int             @id @default(autoincrement())
  name                          String
  absenceCategory               AbsenceCategory
  attendCountsAsAttendance      Boolean         @default(false)
  attendGrantsPerfectAttendance Boolean         @default(false)
  isActive                      Boolean         @default(true)
  sortOrder                     Int             @default(0)
  createdAt                     DateTime        @default(now())
  updatedAt                     DateTime        @updatedAt

  @@unique([name, absenceCategory])
  @@index([isActive, sortOrder])
  @@map("absence_policies")
}

model NotificationLog {
  id                Int                 @id @default(autoincrement())
  examNumber        String
  type              NotificationType
  channel           NotificationChannel
  message           String
  status            String              @default("sent")
  isRead            Boolean             @default(false)
  readAt            DateTime?
  sentAt            DateTime            @default(now())
  failReason        String?
  templateVariables Json?
  dedupeKey         String?             @unique

  student Student @relation(fields: [examNumber], references: [examNumber], onDelete: Cascade)

  @@index([examNumber, type])
  @@index([examNumber, isRead])
  @@index([status, sentAt])
  @@map("notification_logs")
}

model NotificationTemplate {
  id               String              @id @default(cuid())
  type             NotificationType
  channel          NotificationChannel @default(ALIMTALK)
  solapiTemplateId String?
  content          String
  variables        String[]            @default([])
  description      String              @default("")
  updatedAt        DateTime            @updatedAt
  updatedBy        String              @db.Uuid

  @@unique([type, channel])
  @@index([type])
  @@map("notification_templates")
}

model WeeklyStatusSnapshot {
  id                Int            @id @default(autoincrement())
  periodId          Int
  examNumber        String
  examType          ExamType
  weekKey           String
  weekStartDate     DateTime
  weekEndDate       DateTime
  weekAbsenceCount  Int            @default(0)
  monthAbsenceCount Int            @default(0)
  status            StudentStatus
  recoveryDate      DateTime?
  dropoutReason     DropoutReason?
  calculatedAt      DateTime       @default(now())
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  period  ExamPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)
  student Student    @relation(fields: [examNumber], references: [examNumber], onDelete: Cascade)

  @@unique([periodId, examNumber, weekKey])
  @@index([periodId, examType, weekKey, status])
  @@index([examNumber, weekStartDate])
  @@map("weekly_status_snapshots")
}

model CounselingRecord {
  id             Int       @id @default(autoincrement())
  examNumber     String
  counselorName  String
  content        String
  recommendation String?
  nextSchedule   DateTime?
  counseledAt    DateTime
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  student Student @relation(fields: [examNumber], references: [examNumber], onDelete: Cascade)

  @@index([examNumber, counseledAt])
  @@map("counseling_records")
}

model CounselingAppointment {
  id            Int               @id @default(autoincrement())
  examNumber    String
  scheduledAt   DateTime
  counselorName String
  agenda        String?
  status        AppointmentStatus @default(SCHEDULED)
  cancelReason  String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  student Student @relation(fields: [examNumber], references: [examNumber], onDelete: Cascade)

  @@index([examNumber, scheduledAt])
  @@index([status, scheduledAt])
  @@map("counseling_appointments")
}

model ExamQuestion {
  id                 Int      @id @default(autoincrement())
  sessionId          Int
  questionNo         Int
  correctAnswer      String
  correctRate        Float?
  difficulty         String?
  answerDistribution Json?
  createdAt          DateTime @default(now())

  questionSession    ExamSession         @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  studentAnswers     StudentAnswer[]
  wrongNoteBookmarks WrongNoteBookmark[]

  @@unique([sessionId, questionNo])
  @@map("exam_questions")
}

model StudentAnswer {
  id         Int      @id @default(autoincrement())
  examNumber String
  questionId Int
  answer     String
  isCorrect  Boolean
  createdAt  DateTime @default(now())

  question ExamQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  student  Student      @relation(fields: [examNumber], references: [examNumber], onDelete: Cascade)

  @@unique([examNumber, questionId])
  @@map("student_answers")
}

model PointLog {
  id         Int       @id @default(autoincrement())
  examNumber String
  type       PointType
  amount     Int
  reason     String
  periodId   Int?
  month      Int?
  year       Int?
  grantedAt  DateTime  @default(now())
  grantedBy  String?

  period  ExamPeriod? @relation(fields: [periodId], references: [id], onDelete: SetNull)
  student Student     @relation(fields: [examNumber], references: [examNumber], onDelete: Cascade)

  @@index([examNumber, grantedAt])
  @@index([periodId, grantedAt])
  @@index([periodId, year, month, type])
  @@map("point_logs")
}

model PointBalance {
  id         String   @id @default(cuid())
  examNumber String   @unique
  balance    Int      @default(0)
  updatedAt  DateTime @updatedAt

  student Student @relation(fields: [examNumber], references: [examNumber])

  @@map("point_balances")
}

model AdminUser {
  id        String    @id @db.Uuid
  email     String    @unique
  name      String
  phone     String?
  role      AdminRole @default(TEACHER)
  academyId Int?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  academy                        Academy?                @relation(fields: [academyId], references: [id], onDelete: SetNull)
  auditLogs                      AuditLog[]
  assignedMemos                  AdminMemo[]             @relation("AdminMemoAssignee")
  ownedMemos                     AdminMemo[]             @relation("AdminMemoOwner")
  scoreDeadlineAlerts            ScoreDeadlineAlertLog[]
  uploadedAbsenceNoteAttachments AbsenceNoteAttachment[] @relation("AbsenceNoteAttachmentUploader")
  staff                          Staff?
  managedEnrollments             CourseEnrollment[]
  processedPayments              Payment[]
  classroomsAsTeacher            Classroom[]             @relation("ClassroomTeacher")
  lockerRentalsCreated           LockerRental[]
  studyRoomBookingsAssigned      StudyRoomBooking[]
  graduateRecordsCreated         GraduateRecord[]        @relation("GraduateRecordStaff")
  issuedDiscountCodes            DiscountCode[]
  paymentLinks                   PaymentLink[]
  textbookSales                  TextbookSale[]
  courseContracts                CourseContract[]
  consultationProspects          ConsultationProspect[]
  enrollmentHistories            EnrollmentHistory[]
  documentIssuances              DocumentIssuance[]      @relation("DocumentIssuances")

  @@index([academyId, role])
  @@map("admin_users")
}

model ScoreDeadlineAlertLog {
  id                Int                 @id @default(autoincrement())
  sessionId         Int
  adminId           String              @db.Uuid
  type              NotificationType    @default(SCORE_DEADLINE)
  channel           NotificationChannel @default(SMS)
  message           String
  status            String              @default("sent")
  sentAt            DateTime            @default(now())
  failReason        String?
  templateVariables Json?
  dedupeKey         String?             @unique
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  admin   AdminUser   @relation(fields: [adminId], references: [id], onDelete: Cascade)
  session ExamSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, sentAt])
  @@index([adminId, sentAt])
  @@index([status, sentAt])
  @@map("score_deadline_alert_logs")
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  adminId    String   @db.Uuid
  action     String
  targetType String
  targetId   String
  before     Json?
  after      Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  admin AdminUser @relation(fields: [adminId], references: [id], onDelete: Restrict)

  @@index([action, createdAt])
  @@index([adminId, createdAt])
  @@map("audit_logs")
}

model Notice {
  id          Int              @id @default(autoincrement())
  title       String
  content     String
  targetType  NoticeTargetType @default(ALL)
  isPinned    Boolean          @default(false)
  isPublished Boolean          @default(false)
  publishedAt DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([targetType, isPublished, isPinned])
  @@map("notices")
}

model AdminMemo {
  id                       Int             @id @default(autoincrement())
  title                    String
  content                  String?
  color                    AdminMemoColor  @default(SAND)
  scope                    AdminMemoScope  @default(PRIVATE)
  status                   AdminMemoStatus @default(OPEN)
  isPinned                 Boolean         @default(false)
  dueAt                    DateTime?
  relatedStudentExamNumber String?
  relatedExamSessionId     Int?
  ownerId                  String          @db.Uuid
  assigneeId               String?         @db.Uuid
  createdAt                DateTime        @default(now())
  updatedAt                DateTime        @updatedAt

  assignee           AdminUser?   @relation("AdminMemoAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  owner              AdminUser    @relation("AdminMemoOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  relatedExamSession ExamSession? @relation("AdminMemoRelatedExamSession", fields: [relatedExamSessionId], references: [id], onDelete: SetNull)

  @@index([scope, status, isPinned])
  @@index([ownerId, status])
  @@index([assigneeId, status])
  @@index([relatedStudentExamNumber])
  @@index([relatedExamSessionId])
  @@map("admin_memos")
}

model PeriodEnrollment {
  id         Int      @id @default(autoincrement())
  periodId   Int
  examNumber String
  enrolledAt DateTime @default(now())

  period  ExamPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)
  student Student    @relation(fields: [examNumber], references: [examNumber], onDelete: Cascade)

  @@unique([periodId, examNumber])
  @@index([periodId])
  @@map("period_enrollments")
}

model WrongNoteBookmark {
  id         Int      @id @default(autoincrement())
  examNumber String
  questionId Int
  memo       String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  question ExamQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  student  Student      @relation(fields: [examNumber], references: [examNumber], onDelete: Cascade)

  @@unique([examNumber, questionId])
  @@map("wrong_note_bookmarks")
}

enum ExamType {
  GONGCHAE
  GYEONGCHAE
}

enum StudentType {
  NEW
  EXISTING
}

enum Subject {
  CONSTITUTIONAL_LAW
  CRIMINOLOGY
  CRIMINAL_PROCEDURE
  CRIMINAL_LAW
  POLICE_SCIENCE
  CUMULATIVE
}

enum AttendType {
  NORMAL
  LIVE
  EXCUSED
  ABSENT
}

enum AbsenceStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AbsenceCategory {
  MILITARY
  MEDICAL
  FAMILY
  OTHER
}

enum NotificationType {
  WARNING_1
  WARNING_2
  DROPOUT
  ABSENCE_NOTE
  POINT
  NOTICE
  SCORE_DEADLINE
  ENROLLMENT_COMPLETE
  PAYMENT_COMPLETE
  REFUND_COMPLETE
  PAYMENT_OVERDUE
}

enum NotificationChannel {
  ALIMTALK
  SMS
  WEB_PUSH
}

enum PointType {
  PERFECT_ATTENDANCE
  SCORE_EXCELLENCE
  ESSAY_EXCELLENCE
  MANUAL
  USE_PAYMENT
  USE_RENTAL
  ADJUST
  EXPIRE
  REFUND_CANCEL
}

enum ScoreSource {
  OFFLINE_UPLOAD
  ONLINE_UPLOAD
  MANUAL_INPUT
  PASTE_INPUT
  MIGRATION
}

enum AdminRole {
  SUPER_ADMIN
  DIRECTOR
  DEPUTY_DIRECTOR
  MANAGER
  ACADEMIC_ADMIN
  COUNSELOR
  TEACHER
  VIEWER
}

enum AcademyType {
  POLICE
  FIRE
  CIVIL_SERVICE
  OTHER
}

enum StudentStatus {
  NORMAL
  WARNING_1
  WARNING_2
  DROPOUT
}

enum DropoutReason {
  WEEKLY_3
  MONTHLY_8
}

enum AppointmentStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum NoticeTargetType {
  ALL
  GONGCHAE
  GYEONGCHAE
}

enum AdminMemoColor {
  SAND
  MINT
  SKY
  ROSE
  SLATE
}

enum AdminMemoScope {
  PRIVATE
  TEAM
}

enum AdminMemoStatus {
  OPEN
  IN_PROGRESS
  DONE
}

enum CourseCategory {
  COMPREHENSIVE
  SINGLE
  SPECIAL
}

enum CourseStatus {
  ACTIVE
  CLOSED
  FINISHED
  CANCELLED
}

model Course {
  id              Int            @id @default(autoincrement())
  name            String
  category        CourseCategory
  examType        ExamType?
  tuitionFee      Int
  description     String?
  status          CourseStatus   @default(ACTIVE)
  isActive        Boolean        @default(true)
  maxCapacity     Int?
  cohortStartDate DateTime?
  cohortEndDate   DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  paymentLinks PaymentLink[]

  @@index([category, status, isActive])
  @@index([examType, isActive])
  @@map("courses")
}

model Textbook {
  id        Int            @id @default(autoincrement())
  title     String
  author    String?
  publisher String?
  price     Int
  stock     Int            @default(0)
  subject   Subject?
  isActive  Boolean        @default(true)
  sales     TextbookSale[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([isActive])
  @@map("textbooks")
}

model TextbookSale {
  id         Int       @id @default(autoincrement())
  textbookId Int
  textbook   Textbook  @relation(fields: [textbookId], references: [id])
  examNumber String?
  staffId    String    @db.Uuid
  staff      AdminUser @relation(fields: [staffId], references: [id])
  quantity   Int       @default(1)
  unitPrice  Int
  totalPrice Int
  note       String?
  soldAt     DateTime  @default(now())

  @@index([textbookId])
  @@index([soldAt])
  @@index([examNumber])
  @@map("textbook_sales")
}

enum StaffRole {
  OWNER
  DIRECTOR
  DEPUTY_DIRECTOR
  MANAGER
  ACADEMIC_ADMIN
  COUNSELOR
  TEACHER
}

model Staff {
  id          String    @id @default(cuid())
  authUid     String    @unique
  email       String    @unique
  name        String
  role        StaffRole
  mobile      String?
  isActive    Boolean   @default(true)
  note        String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  lastLoginAt DateTime?
  adminUserId String?   @unique @db.Uuid

  adminUser AdminUser? @relation(fields: [adminUserId], references: [id], onDelete: SetNull)

  @@index([role, isActive])
  @@map("staffs")
}

enum ExamCategory {
  GONGCHAE
  GYEONGCHAE
  SOGANG
  CUSTOM
}

enum CourseType {
  COMPREHENSIVE
  SPECIAL_LECTURE
}

enum EnrollmentStatus {
  PENDING
  ACTIVE
  WAITING
  SUSPENDED
  COMPLETED
  WITHDRAWN
  CANCELLED
}

enum EnrollSource {
  VISIT
  PHONE
  ONLINE
  REFERRAL
  SNS
  OTHER
}

enum MemberStatus {
  ACTIVE
  SUSPENDED
  WITHDRAWN
  GRADUATED
}

enum SpecialLectureType {
  THEMED
  SINGLE
  INTERVIEW_COACHING
}

enum SettlementStatus {
  PENDING
  PAID
  CANCELLED
}

enum FieldType {
  TEXT
  SELECT
  CHECKBOX
  DATE
  NUMBER
  MULTI_SELECT
}

enum DiscountType {
  RATE
  FIXED
}

model Instructor {
  id          String   @id @default(cuid())
  name        String
  subject     String
  phone       String?
  email       String?
  bankName    String?
  bankAccount String?
  bankHolder  String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lectureSubjects SpecialLectureSubject[]
  settlements     InstructorSettlement[]

