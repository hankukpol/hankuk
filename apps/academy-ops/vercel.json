{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "pnpm build",
  "ignoreCommand": "node ../../scripts/vercel-ignore.mjs academy-ops",
  "regions": [
    "icn1"
  ],
  "crons": [
    {
      "path": "/api/cron/payment-links-expiry",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/enrollment-expiry",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/cron/daily-settlement",
      "schedule": "5 1 * * *"
    },
    {
      "path": "/api/cron/score-deadline",
      "schedule": "0 18 * * *"
    },
    {
      "path": "/api/cron/weekly-report",
      "schedule": "0 8 * * 1"
    },
    {
      "path": "/api/cron/payment-reminders",
      "schedule": "0 0 * * *"
    }
  ]
}
